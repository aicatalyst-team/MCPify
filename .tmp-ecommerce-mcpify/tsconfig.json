{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "outDir": "dist",
    "rootDir": "..",
    "declaration": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowJs": true,
    "checkJs": false
  },
  "include": [
    "./**/*.ts",
    "../examples/ecommerce-saas/src/services/orders.ts",
    "../examples/ecommerce-saas/src/services/support.ts",
    "../examples/ecommerce-saas/src/services/users.ts",
    "../examples/ecommerce-saas/src/components/AdminDashboard.tsx",
    "../examples/ecommerce-saas/src/components/CartPage.tsx"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}
