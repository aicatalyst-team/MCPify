{
  "name": "ecommerce-saas-example",
  "version": "1.0.0",
  "private": true,
  "description": "Example SaaS application that MCPify can analyze",
  "scripts": {
    "dev":             "vite --host 127.0.0.1",
    "build":           "tsc --noEmit && vite build",
    "preview":         "vite preview --host 127.0.0.1",
    "mcpify":          "node ../../packages/cli/dist/index.js analyze . --output .mcpify --prisma prisma/schema.prisma --swagger openapi.json",
    "mcpify:enhance":  "node ../../packages/cli/dist/index.js analyze . --output .mcpify --prisma prisma/schema.prisma --swagger openapi.json --ai-enhance",
    "mcpify:audit":    "node ../../packages/cli/dist/index.js audit .",
    "mcpify:watch":    "node ../../packages/cli/dist/index.js analyze . --output .mcpify --prisma prisma/schema.prisma --swagger openapi.json --watch",
    "mcpify:simulate": "node ../../packages/cli/dist/index.js simulate .",
    "mcpify:smoke":    "node scripts/smoke-mcp.mjs"
  },
  "dependencies": {
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "@prisma/client": "^5.0.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^5.0.4",
    "typescript": "^5.4.0",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "@types/node": "^20.0.0",
    "prisma": "^5.0.0",
    "vite": "^7.3.1"
  }
}
